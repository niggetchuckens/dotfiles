{
    "apps": [
        {
            "auto-detach": true,
            "cmd": "",
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "/home/hime/.config/sunshine/icons/desktop.jpg",
            "name": "Desktop",
            "prep-cmd": [
                {
                    "do": "/home/hime/.config/sunshine/scripts/set_resolution.sh",
                    "undo": "/home/hime/.config/sunshine/scripts/reset_resolution.sh"
                }
            ],
            "wait-all": true
        },
        {
            "auto-detach": true,
            "cmd": "code",
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "vscode.png",
            "name": "Visual Studio Code",
            "prep-cmd": [
                {
                    "do": "/home/hime/.config/sunshine/scripts/set_resolution.sh",
                    "undo": "/home/hime/.config/sunshine/scripts/reset_resolution.sh"
                }
            ]
        },
        {
            "auto-detach": true,
            "detached": [
                "steam steam://open/bigpicture"
            ],
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "steam.png",
            "name": "Steam Big Picture",
            "prep-cmd": [
                {
                    "do": "/home/hime/.config/sunshine/scripts/set_resolution.sh",
                    "undo": "/home/hime/.config/sunshine/scripts/reset_resolution.sh"
                },
                {
                    "do": "",
                    "undo": "steam steam://close/bigpicture"
                }
            ]
        }
